<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Extreme Slug Racing — Order Form</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: Arial, sans-serif;
    background: #1a1a1a;
    color: #fff;
    padding: 20px;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    padding: 24px 20px;
    background: #111;
    border-radius: 12px;
    margin-bottom: 20px;
    border: 1px solid #333;
  }
  .header h1 {
    color: #FFB800;
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 6px;
  }
  .header p { color: #aaa; font-size: 12px; line-height: 1.6; }
  .header .slug { font-size: 28px; margin-bottom: 8px; }

  /* ── Sections ── */
  .section {
    background: #222;
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 16px;
    border: 1px solid #333;
  }
  .section-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #FFB800;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid #333;
  }

  /* ── Form fields ── */
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  .field-row.single { grid-template-columns: 1fr; }
  .field-row.triple { grid-template-columns: 1fr 1fr 1fr; }
  .field { display: flex; flex-direction: column; }
  label {
    font-size: 11px;
    font-weight: 700;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 5px;
  }
  label .req { color: #FFB800; }
  input, select, textarea {
    background: #333;
    border: 1px solid #444;
    border-radius: 6px;
    color: #fff;
    font-size: 13px;
    padding: 9px 12px;
    transition: border-color 0.15s;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: #FFB800;
    background: #3a3a3a;
  }
  select option { background: #333; color: #fff; }
  textarea { resize: vertical; min-height: 70px; }

  /* ── Item rows ── */
  .item-block {
    background: #1a1a1a;
    border-radius: 8px;
    padding: 14px;
    margin-bottom: 12px;
    border: 1px solid #3a3a3a;
  }
  .item-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .item-label {
    font-size: 12px;
    font-weight: 700;
    color: #FFB800;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .item-price {
    font-size: 16px;
    font-weight: 900;
    color: #fff;
  }
  .remove-btn {
    background: #444;
    border: none;
    color: #aaa;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
  }
  .remove-btn:hover { background: #c0392b; color: #fff; }

  .add-item-btn {
    width: 100%;
    padding: 10px;
    background: #333;
    border: 1px dashed #555;
    border-radius: 8px;
    color: #aaa;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
    margin-top: 4px;
  }
  .add-item-btn:hover { background: #3a3a3a; border-color: #FFB800; color: #FFB800; }

  /* ── Totals ── */
  .totals-box {
    background: #111;
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 16px;
    border: 1px solid #333;
  }
  .total-row {
    display: flex;
    justify-content: space-between;
    padding: 5px 0;
    font-size: 13px;
    color: #aaa;
    border-bottom: 1px solid #2a2a2a;
  }
  .total-row:last-child { border-bottom: none; }
  .total-row.grand {
    font-size: 18px;
    font-weight: 900;
    color: #FFB800;
    padding-top: 10px;
    margin-top: 4px;
  }
  .total-row.grand span:last-child { color: #fff; }

  /* ── Shipping note ── */
  .shipping-note {
    background: #8B2FC9;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  /* ── Payment info ── */
  .paypal-note {
    background: #003087;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 12px;
    color: #fff;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .paypal-note strong { color: #FFB800; }

  /* ── Submit ── */
  .submit-btn {
    width: 100%;
    padding: 16px;
    background: #FFB800;
    border: none;
    border-radius: 10px;
    color: #111;
    font-size: 16px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .submit-btn:hover { background: #e6a800; }
  .submit-btn:disabled { background: #555; color: #888; cursor: default; }

  /* ── Success message ── */
  .success-msg {
    display: none;
    background: #1e7e34;
    border-radius: 10px;
    padding: 24px;
    text-align: center;
    margin-top: 16px;
  }
  .success-msg h2 { color: #fff; font-size: 20px; margin-bottom: 8px; }
  .success-msg p { color: #ccc; font-size: 13px; line-height: 1.6; }

  /* ── Disclaimer ── */
  .disclaimer {
    text-align: center;
    font-size: 11px;
    color: #666;
    margin-top: 16px;
    line-height: 1.6;
  }

  /* ── Mobile ── */
  @media (max-width: 500px) {
    .field-row { grid-template-columns: 1fr; }
    .field-row.triple { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="slug">🐌</div>
  <h1>Extreme Slug Racing — Order Form</h1>
  <p>Fill out this form and Sam will personally handle your order.<br>
  You'll receive a PayPal invoice by email within 24 hours.<br>
  <strong style="color:#FFB800;">Please allow 30-45 days for delivery on all items.</strong></p>
</div>

<form id="orderForm">

  <!-- ── CUSTOMER INFO ── -->
  <div class="section">
    <div class="section-title">👤 Your Information</div>
    <div class="field-row">
      <div class="field">
        <label>First Name <span class="req">*</span></label>
        <input type="text" id="firstName" required placeholder="First name">
      </div>
      <div class="field">
        <label>Last Name <span class="req">*</span></label>
        <input type="text" id="lastName" required placeholder="Last name">
      </div>
    </div>
    <div class="field-row">
      <div class="field">
        <label>Email Address <span class="req">*</span></label>
        <input type="email" id="email" required placeholder="you@email.com">
      </div>
      <div class="field">
        <label>Phone (optional)</label>
        <input type="tel" id="phone" placeholder="(360) 555-0000">
      </div>
    </div>
  </div>

  <!-- ── SHIPPING ADDRESS ── -->
  <div class="section">
    <div class="section-title">📦 Shipping Address</div>
    <div class="field-row single">
      <div class="field">
        <label>Street Address <span class="req">*</span></label>
        <input type="text" id="address" required placeholder="123 Main Street">
      </div>
    </div>
    <div class="field-row single">
      <div class="field">
        <label>Apt / Suite / Unit (optional)</label>
        <input type="text" id="address2" placeholder="Apt 4B">
      </div>
    </div>
    <div class="field-row triple">
      <div class="field">
        <label>City <span class="req">*</span></label>
        <input type="text" id="city" required placeholder="City">
      </div>
      <div class="field">
        <label>State <span class="req">*</span></label>
        <input type="text" id="state" required placeholder="WA" maxlength="2">
      </div>
      <div class="field">
        <label>ZIP Code <span class="req">*</span></label>
        <input type="text" id="zip" required placeholder="98363" maxlength="10">
      </div>
    </div>
    <div class="field-row single">
      <div class="field">
        <label>Country</label>
        <select id="country">
          <option value="USA">United States</option>
          <option value="Canada">Canada</option>
          <option value="Australia">Australia</option>
          <option value="UK">United Kingdom</option>
          <option value="Other">Other (contact us first)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- ── ORDER ITEMS ── -->
  <div class="section">
    <div class="section-title">🛒 Your Order</div>
    <div id="items-container">
      <!-- Item rows injected here by JS -->
    </div>
    <button type="button" class="add-item-btn" onclick="addItem()">+ Add Another Item</button>
  </div>

  <!-- ── SHIPPING NOTE ── -->
  <div class="shipping-note">
    🚢 <strong>Shipping:</strong> All ArtsAdd items ship from overseas. Flat rate shipping:
    $6 for orders under $20 &nbsp;•&nbsp; $8 for orders $20–$40 &nbsp;•&nbsp; $10 for orders over $40.
    Please allow <strong>30–45 days</strong> for delivery. You will receive a tracking number when your order ships.
  </div>

  <!-- ── ORDER TOTALS ── -->
  <div class="totals-box">
    <div class="total-row"><span>Items subtotal</span><span id="subtotal-display">$0.00</span></div>
    <div class="total-row"><span>Flat rate shipping</span><span id="shipping-display">$0.00</span></div>
    <div class="total-row grand"><span>Total due via PayPal</span><span id="total-display">$0.00</span></div>
  </div>

  <!-- ── SPECIAL INSTRUCTIONS ── -->
  <div class="section">
    <div class="section-title">📝 Special Instructions (optional)</div>
    <div class="field-row single">
      <div class="field">
        <textarea id="notes" placeholder="Gift wrapping requests, questions about sizing, Race Day pickup preference, etc."></textarea>
      </div>
    </div>
  </div>

  <!-- ── PAYPAL NOTE ── -->
  <div class="paypal-note">
    <strong>💳 How payment works:</strong><br>
    After submitting this form, Sam will email you a PayPal invoice within 24 hours.
    You do NOT need a PayPal account — you can pay by credit or debit card through PayPal's secure checkout.
    Your order will be placed with ArtsAdd as soon as payment is received.
  </div>

  <!-- ── SUBMIT ── -->
  <button type="submit" class="submit-btn" id="submitBtn">
    🐌 Submit My Order
  </button>

</form>

<!-- ── SUCCESS MESSAGE ── -->
<div class="success-msg" id="successMsg">
  <h2>🐌 Order Received!</h2>
  <p>Thank you! Sam will email you a PayPal invoice within 24 hours.<br>
  Please check your spam folder if you don't hear back.<br><br>
  <strong style="color:#FFB800;">Race Day is August 1, 2026 — Joyce Family Kitchen Beer Garden — Post time 2:30pm</strong><br><br>
  100% of Race Day proceeds benefit Clallam County Fire Protection District No. 4.</p>
</div>

<div class="disclaimer">
  slugraces.com &nbsp;•&nbsp; Joyce, WA &nbsp;•&nbsp; Est. 2015<br>
  Questions? Email <strong>INSERT-YOUR-EMAIL-HERE</strong> or visit <strong>slugraces.com</strong>
</div>

<script>
// ══════════════════════════════════════════════
// PRODUCT CATALOG
// ══════════════════════════════════════════════
const PRODUCTS = [
  { id: '',          name: '— Select a product —',                         price: 0 },
  { id: 'AAOLBC-2601', name: 'Official Logo Baseball Cap',                 price: 9.98 },
  { id: 'AACLBC-2602', name: 'Color Logo Baseball Cap',                    price: 9.98 },
  { id: 'AARLBC-2603', name: 'Rainbow Logo Baseball Cap',                  price: 9.98 },
  { id: 'AARPKB-2606', name: 'Rainbow Print Knit Beanie',                  price: 18.57 },
  { id: 'AARISV-2607', name: 'Rainbow Women\'s Ice Silk V-Neck',           price: 19.75 },
  { id: 'AARBWV-2608', name: 'Rainbow Women\'s Bat Wing Sleeve V-Neck',    price: 19.36 },
  { id: 'AAPWLV-2609', name: 'Purple Women\'s Lace V-Neck',                price: 17.95 },
  { id: 'AARCWH-2610', name: 'Race Car Women\'s Hoodie',                   price: 33.35 },
  { id: 'AAFPHS-2617', name: 'Floral Print Hawaiian Shirt',                price: 39.23 },
  { id: 'AASRCL-2618', name: 'Slug Racer Color Logo Print Tee',            price: 17.97 },
  { id: 'AASRAO-2619', name: 'Slug Racer All Over Print Tee',              price: 21.92 },
  { id: 'AASJMP-2620', name: 'Slug Jockey Men\'s Plus Size Tee',           price: 18.68 },
  { id: 'AAJFRH-2621', name: 'Joyce Fire Rescue Men\'s Hoodie',            price: 33.76 },
  { id: 'AASIWS-2621', name: 'Slug ID Women\'s Socks',                     price: 12.35 },
  { id: 'AAERWS-2622', name: 'Extreme Racing Women\'s Socks',              price: 12.35 },
  { id: 'AAFPWS-2623', name: 'Floral Print Women\'s Slide Sandal',         price: 22.38 },
  { id: 'AASIMS-2624', name: 'Slug ID Men\'s Socks',                       price: 12.40 },
  { id: 'AAERMS-2625', name: 'Extreme Racing Men\'s Socks',                price: 12.40 },
  { id: 'AAESMS-2626', name: 'Extreme Slug Racing Men\'s Slide Sandal',    price: 22.79 },
];

// Color options per product category
const COLORS = {
  cap:     ['Black', 'White', 'Beige', 'Army Green'],
  cap2:    ['Black', 'White', 'Stone', 'Hunter Green', 'Navy'],
  beanie:  ['Black'],
  tops:    ['Black'],
  hoodie:  ['Black'],
  hawaiian:['One size / all over print'],
  socks:   ['White/Multi print'],
  slides:  ['Black'],
};

function getColors(id) {
  if (['AAOLBC-2601','AACLBC-2602','AARLBC-2603'].includes(id)) return COLORS.cap;
  if (id === 'AARPKB-2606') return COLORS.beanie;
  if (['AAFPHS-2617'].includes(id)) return COLORS.hawaiian;
  if (['AASIWS-2621','AAERWS-2622','AASIMS-2624','AAERMS-2625'].includes(id)) return COLORS.socks;
  if (['AAFPWS-2623','AAESMS-2626'].includes(id)) return COLORS.slides;
  return COLORS.tops;
}

// Size options
function getSizes(id) {
  if (['AAOLBC-2601','AACLBC-2602','AARLBC-2603','AARPKB-2606'].includes(id))
    return ['One Size Fits Most'];
  if (['AAFPWS-2623'].includes(id))
    return ['US5.5','US6','US7','US8','US8.5','US9.5','US10','US11','US12.5','US14'];
  if (['AAESMS-2626'].includes(id))
    return ['US5.5','US6.5','US7.5','US8','US9','US9.5','US10.5','US11.5','US12.5','US13'];
  if (['AASIWS-2621','AAERWS-2622'].includes(id))
    return ['Women S/M (shoe 5-8)','Women L/XL (shoe 8.5-12)'];
  if (['AASIMS-2624','AAERMS-2625'].includes(id))
    return ['Men S/M (shoe 6-9)','Men L/XL (shoe 9.5-13)'];
  if (['AAFPHS-2617'].includes(id))
    return ['S','M','L','XL','2XL','3XL','4XL','5XL'];
  return ['XS','S','M','L','XL','2XL','3XL','4XL','5XL'];
}

// ══════════════════════════════════════════════
// ITEM ROW BUILDER
// ══════════════════════════════════════════════
let itemCount = 0;

function addItem() {
  if (itemCount >= 5) {
    alert('Maximum 5 items per order. For larger orders please email us directly.');
    return;
  }
  itemCount++;
  const n = itemCount;

  // Build product options
  let productOptions = PRODUCTS.map(p =>
    `<option value="${p.id}" data-price="${p.price}">${p.id ? p.id + ' — ' : ''}${p.name}${p.price > 0 ? ' ($' + p.price.toFixed(2) + ')' : ''}</option>`
  ).join('');

  const html = `
    <div class="item-block" id="item-block-${n}">
      <div class="item-header">
        <span class="item-label">Item ${n}</span>
        <span class="item-price" id="item-price-${n}">$0.00</span>
        ${n > 1 ? `<button type="button" class="remove-btn" onclick="removeItem(${n})">✕ Remove</button>` : ''}
      </div>
      <div class="field-row single">
        <div class="field">
          <label>Product <span class="req">*</span></label>
          <select id="product-${n}" onchange="onProductChange(${n})" required>
            ${productOptions}
          </select>
        </div>
      </div>
      <div class="field-row" id="options-row-${n}" style="display:none;">
        <div class="field">
          <label>Color <span class="req">*</span></label>
          <select id="color-${n}" required>
            <option value="">— Select color —</option>
          </select>
        </div>
        <div class="field">
          <label>Size <span class="req">*</span></label>
          <select id="size-${n}" required>
            <option value="">— Select size —</option>
          </select>
        </div>
      </div>
      <div class="field-row" id="qty-row-${n}" style="display:none;">
        <div class="field">
          <label>Quantity <span class="req">*</span></label>
          <select id="qty-${n}" onchange="updateTotals()" required>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
          </select>
        </div>
        <div class="field" style="display:flex; align-items:flex-end;">
          <div style="font-size:11px; color:#888; padding-bottom:10px; line-height:1.5;">
            See size chart on slugraces.com<br>before selecting size
          </div>
        </div>
      </div>
    </div>
  `;

  document.getElementById('items-container').insertAdjacentHTML('beforeend', html);
  updateTotals();
}

function removeItem(n) {
  const block = document.getElementById('item-block-' + n);
  if (block) block.remove();
  updateTotals();
}

function onProductChange(n) {
  const select = document.getElementById('product-' + n);
  const selectedOption = select.options[select.selectedIndex];
  const price = parseFloat(selectedOption.getAttribute('data-price')) || 0;
  const id = select.value;

  // Update price display
  document.getElementById('item-price-' + n).textContent = price > 0 ? '$' + price.toFixed(2) : '$0.00';

  // Show/hide options
  const optionsRow = document.getElementById('options-row-' + n);
  const qtyRow = document.getElementById('qty-row-' + n);

  if (id) {
    optionsRow.style.display = '';
    qtyRow.style.display = '';

    // Populate colors
    const colorSelect = document.getElementById('color-' + n);
    colorSelect.innerHTML = '<option value="">— Select color —</option>';
    getColors(id).forEach(c => {
      colorSelect.insertAdjacentHTML('beforeend', `<option value="${c}">${c}</option>`);
    });

    // Populate sizes
    const sizeSelect = document.getElementById('size-' + n);
    sizeSelect.innerHTML = '<option value="">— Select size —</option>';
    getSizes(id).forEach(s => {
      sizeSelect.insertAdjacentHTML('beforeend', `<option value="${s}">${s}</option>`);
    });

    // Auto-select if only one option
    if (getColors(id).length === 1) colorSelect.value = getColors(id)[0];
    if (getSizes(id).length === 1) sizeSelect.value = getSizes(id)[0];

  } else {
    optionsRow.style.display = 'none';
    qtyRow.style.display = 'none';
  }

  updateTotals();
}

// ══════════════════════════════════════════════
// TOTALS CALCULATOR
// ══════════════════════════════════════════════
function updateTotals() {
  let subtotal = 0;

  for (let i = 1; i <= itemCount; i++) {
    const block = document.getElementById('item-block-' + i);
    if (!block) continue;
    const productSelect = document.getElementById('product-' + i);
    if (!productSelect) continue;
    const price = parseFloat(productSelect.options[productSelect.selectedIndex]?.getAttribute('data-price')) || 0;
    const qty = parseInt(document.getElementById('qty-' + i)?.value) || 1;
    const itemTotal = price * qty;
    subtotal += itemTotal;
    const priceEl = document.getElementById('item-price-' + i);
    if (priceEl) priceEl.textContent = '$' + itemTotal.toFixed(2);
  }

  // Flat rate shipping
  let shipping = 0;
  if (subtotal > 0 && subtotal <= 20) shipping = 6.00;
  else if (subtotal > 20 && subtotal <= 40) shipping = 8.00;
  else if (subtotal > 40) shipping = 10.00;

  const total = subtotal + shipping;

  document.getElementById('subtotal-display').textContent = '$' + subtotal.toFixed(2);
  document.getElementById('shipping-display').textContent = shipping > 0 ? '$' + shipping.toFixed(2) : '—';
  document.getElementById('total-display').textContent = '$' + total.toFixed(2);
}

// ══════════════════════════════════════════════
// FORM SUBMISSION via Formspree
// Replace YOUR_FORMSPREE_ID with your actual ID
// Get a free endpoint at formspree.io
// ══════════════════════════════════════════════
document.getElementById('orderForm').addEventListener('submit', async function(e) {
  e.preventDefault();

  // Validate at least one product selected
  let hasProduct = false;
  for (let i = 1; i <= itemCount; i++) {
    const ps = document.getElementById('product-' + i);
    if (ps && ps.value) { hasProduct = true; break; }
  }
  if (!hasProduct) {
    alert('Please add at least one item to your order.');
    return;
  }

  // Build order summary
  let orderLines = [];
  let subtotal = 0;
  for (let i = 1; i <= itemCount; i++) {
    const block = document.getElementById('item-block-' + i);
    if (!block) continue;
    const ps = document.getElementById('product-' + i);
    if (!ps || !ps.value) continue;
    const productName = ps.options[ps.selectedIndex].text;
    const price = parseFloat(ps.options[ps.selectedIndex].getAttribute('data-price')) || 0;
    const color = document.getElementById('color-' + i)?.value || '';
    const size = document.getElementById('size-' + i)?.value || '';
    const qty = parseInt(document.getElementById('qty-' + i)?.value) || 1;
    const lineTotal = price * qty;
    subtotal += lineTotal;
    orderLines.push(`${productName} | Color: ${color} | Size: ${size} | Qty: ${qty} | $${lineTotal.toFixed(2)}`);
  }

  let shipping = 0;
  if (subtotal <= 20) shipping = 6.00;
  else if (subtotal <= 40) shipping = 8.00;
  else shipping = 10.00;
  const total = subtotal + shipping;

  const formData = {
    name: document.getElementById('firstName').value + ' ' + document.getElementById('lastName').value,
    email: document.getElementById('email').value,
    phone: document.getElementById('phone').value || 'Not provided',
    address: [
      document.getElementById('address').value,
      document.getElementById('address2').value,
      document.getElementById('city').value,
      document.getElementById('state').value,
      document.getElementById('zip').value,
      document.getElementById('country').value
    ].filter(Boolean).join(', '),
    order_items: orderLines.join('\n'),
    subtotal: '$' + subtotal.toFixed(2),
    shipping: '$' + shipping.toFixed(2),
    total: '$' + total.toFixed(2),
    notes: document.getElementById('notes').value || 'None',
    _subject: '🐌 New Slug Race Order from ' + document.getElementById('firstName').value + ' — $' + total.toFixed(2),
  };

  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  try {
    // ── REPLACE YOUR_FORMSPREE_ID BELOW ──
    const response = await fetch('https://formspree.io/f/xnjkvzpa', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(formData)
    });

    if (response.ok) {
      document.getElementById('orderForm').style.display = 'none';
      document.getElementById('successMsg').style.display = 'block';
    } else {
      throw new Error('Submission failed');
    }
  } catch (err) {
    btn.disabled = false;
    btn.textContent = '🐌 Submit My Order';
    alert('There was an error submitting your order. Please email us directly at INSERT-YOUR-EMAIL-HERE and we\'ll get you sorted!');
  }
});

// Add first item automatically on load
addItem();

// Auto-select product from URL parameter
window.addEventListener('load', function() {
  const params = new URLSearchParams(window.location.search);
  const preselect = params.get('item');
  if (preselect) {
    const productSelect = document.getElementById('product-1');
    if (productSelect) {
      productSelect.value = preselect;
      onProductChange(1);
    }
  }
});
</script>

